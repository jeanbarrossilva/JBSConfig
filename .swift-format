{
  "lineBreakAroundMultilineExpressionChainComponents": true,
  "lineBreakBeforeEachArgument": true,
  "lineBreakBetweenDeclarationAttributes": true,
  "lineLength": 80,
  "multiElementCollectionTrailingCommas": false,
  "multilineTrailingCommaBehavior": "neverUsed",
  "orderedImports": {
    "includeConditionalImports": true,
    "shouldGroupImports": true
  },
  "prioritizeKeepingFunctionOutputTogether": true,
  "respectsExistingLineBreaks": false,
  "rules": {
    "AvoidRetroactiveConformances": false
  },
  "spacesBeforeEndOfLineComments": 1,
  "tabWidth": 2,
  "version": 1
}
